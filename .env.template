# Google Analytics GA4
# Property ID: GA4 Admin → Property Settings → Property ID (numeric only, no "G-" prefix)
GOOGLE_ANALYTICS_PROPERTY_ID=

# Google Service Account credentials
# All values come from the JSON key file downloaded when creating a Service Account key
# in Google Cloud Console → IAM & Admin → Service Accounts → Keys → Add Key → JSON
GOOGLE_CLIENT_EMAIL=
GOOGLE_CLIENT_ID=
# Paste the private_key value exactly as-is from the JSON file (including quotes and \n chars)
GOOGLE_PRIVATE_KEY=
