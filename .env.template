# Google AdSense
# Publisher ID from adsense.google.com (without the "ca-pub-" prefix is fine to keep full)
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
# Ad slot ID from the specific ad unit created in AdSense dashboard
NEXT_PUBLIC_ADSENSE_CALCULATOR_SLOT=XXXXXXXXXX

# Google Analytics GA4
# Property ID: GA4 Admin → Property Settings → Property ID (numeric only, no "G-" prefix)
GOOGLE_ANALYTICS_PROPERTY_ID=XXXXXXXXX

# Google Service Account credentials
# All values come from the JSON key file downloaded when creating a Service Account key
# in Google Cloud Console → IAM & Admin → Service Accounts → Keys → Add Key → JSON
GOOGLE_CLIENT_EMAIL=
GOOGLE_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXX
# Paste the private_key value exactly as-is from the JSON file (including quotes and \n chars)
GOOGLE_PRIVATE_KEY=""

# Giscus comments
NEXT_PUBLIC_GISCUS_REPO=owner/repo
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
